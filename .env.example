# SafeCircle AI Environment Configurations Example

# Frontend Configurations
VITE_APP_ENV=development
VITE_MAPBOX_API_KEY=your_mapbox_key_here
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_key_here

# Backend Server Configurations
PORT=5000
NODE_ENV=development

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/safecircle

# Third-Party Helplines & Telemetries
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_PHONE_NUMBER=your_twilio_phone
POLICE_RECEPTION_API_URL=https://helpline.gov.in/api/v1/sos
