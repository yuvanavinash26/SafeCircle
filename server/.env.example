# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
MONGODB_URI=mongodb://127.0.0.1:27017/safecircle

# Authentication Configuration
JWT_SECRET=super_secret_jwt_key_placeholder_for_safecircle_app_2026
JWT_EXPIRES_IN=7d

# CORS Configuration (Frontend URL)
CORS_ORIGIN=http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# External AI & Maps Services (Placeholders)
VOICE_AI_API_KEY=mock_voice_ai_key_placeholder
MAPS_API_KEY=mock_maps_key_placeholder
SMS_API_KEY=mock_sms_key_placeholder
EMAIL_API_KEY=mock_email_key_placeholder
